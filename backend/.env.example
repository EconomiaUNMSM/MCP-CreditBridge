# MCP-CreditBridge Configuration

# Selection: openai, google, openrouter
PROVIDER="openai"

# API Keys (Replace these with your actual keys and DO NOT commit this file to GitHub)
OPENAI_API_KEY="your_openai_api_key_here"
OPENROUTER_API_KEY="your_openrouter_key_here"
GEMINI_API_KEY="your_gemini_key_here"

# Note: Google usage via litellm typically uses GOOGLE_API_KEY
GOOGLE_API_KEY="your_google_key_here"
